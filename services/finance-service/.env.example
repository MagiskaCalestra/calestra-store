# finance-service
# Backend for ekonomi (Admin använder denna via VITE_FINANCE_URL / Vite proxy)

PORT=14010

# default mode: test | live
FINANCE_MODE_DEFAULT=test

# butikens "går runt"-mål (per dag i SEK)
DAILY_TARGET_SEK=65000

# Stripe keys (lägg in i TEST först)
STRIPE_TEST_SECRET_KEY=sk_test_xxx
STRIPE_LIVE_SECRET_KEY=sk_live_xxx

# CORS (om du *någon gång* anropar finance-service direkt från browsern)
# I normal dev kör vi via Vite proxy så CORS behövs knappt, men bra att ha.
CORS_ORIGINS=http://localhost:5179,http://localhost:5180,http://localhost:5175,http://localhost:5176,http://localhost:5288,http://localhost:5289
